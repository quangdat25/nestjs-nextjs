{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: NestJS debug",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "command": "npm run start:debug",
      "env": {
        "PORT": "3001"
      },
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Backend: attach to NestJS",
      "type": "node",
      "request": "attach",
      "cwd": "${workspaceFolder}/backend",
      "address": "localhost",
      "port": 9229,
      "restart": true,
      "localRoot": "${workspaceFolder}/backend",
      "remoteRoot": "${workspaceFolder}/backend",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/backend/dist/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/backend/dist/**/*.js",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Frontend: Next.js full stack",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "command": "npm run dev -- --port 3000",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Frontend: browser only",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full stack: NestJS + Next.js",
      "configurations": [
        "Backend: NestJS debug",
        "Frontend: Next.js full stack"
      ],
      "stopAll": true
    }
  ]
}
